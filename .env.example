# ===== DCOM Proxy Box Configuration =====

# Secret key to login to the dashboard (also used as External API key)
SECRET_KEY=changeme123

# Web dashboard port
PORT=8080

# Session secret (generate a random string)
SESSION_SECRET=replace-with-random-secret-string

# Proxy port range start (each dcom gets port: START_PORT + index)
PROXY_START_PORT=10000

# 3proxy config file path
PROXY_CONFIG_PATH=/etc/3proxy/3proxy.cfg

# 3proxy log directory
PROXY_LOG_DIR=/var/log/3proxy

# IP rotation method: hilink | interface | at_command
IP_ROTATE_METHOD=hilink

# Default proxy auth (can be overridden per-dcom in dashboard)
DEFAULT_PROXY_USER=proxyuser
DEFAULT_PROXY_PASS=proxypass

# ===== Cloudflare DDNS (Required) =====
# All 3 fields are REQUIRED — setup/update will prompt for these
# Get API token: https://dash.cloudflare.com/profile/api-tokens (Edit zone DNS)
# Zone ID: Cloudflare Dashboard → your domain → Overview → right sidebar
# DNS record must be set to "DNS only" (grey cloud), NOT "Proxied" (orange cloud)
CF_API_TOKEN=
CF_ZONE_ID=
CF_DDNS_DOMAIN=
